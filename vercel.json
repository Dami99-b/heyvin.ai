{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/api/index?__vercel_original_path=/api/:match*"
    },
    {
      "source": "/auth/:match*",
      "destination": "/api/index?__vercel_original_path=/auth/:match*"
    },
    {
      "source": "/oauth/:match*",
      "destination": "/api/index?__vercel_original_path=/oauth/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
