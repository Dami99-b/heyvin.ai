{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/api/index?__vercel_original_path=/api/:match*"
    },
    {
      "source": "/auth/callback",
      "destination": "/api/index?__vercel_original_path=/auth/callback"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
