# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=

# Google Sign-in OAuth Credentials (if you want to turn off sandbox mode and use real Google accounts)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Enforced OAuth redirect callback URL (e.g. https://vault-ai-lac.vercel.app/auth/callback)
GOOGLE_REDIRECT_URI=

# Supabase Production Database Credentials (if keys are absent, app will run in offline-first mode seamlessly)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Paystack Hosted Transaction Gateway Secret Key (if keys are absent, automated simulation mode will trigger)
PAYSTACK_SECRET_KEY=
